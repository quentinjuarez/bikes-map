{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "vue"],
  "env": {
    "browser": true,
    "es6": true
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/no-unused-vars": "warn"
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "*.config.ts"]
}
